%% refs.bib — Bibliography for an anvil:pub paper
%%
%% Entries come from one of two sources:
%%   1. Author-supplied: <thread>/refs.bib (copied into the version dir by pub-draft)
%%   2. Litsearch sibling: <thread>.{N}.litsearch/candidates.bib (merged by pub-draft / pub-revise
%%      for entries actually cited in main.tex; uncited entries stay in the litsearch sibling)
%%
%% This template starts empty. Do NOT add entries here directly during drafting --
%% the drafter is responsible for merging from the two sources above. Uncited
%% entries should not pollute the final bibliography.
%%
%% Example entry shape (BibTeX, used by natbib via \citep{} and \citet{}):
%%
%% @inproceedings{smith2024example,
%%   author    = {Smith, Jane and Jones, Carol},
%%   title     = {An Example Paper Title},
%%   booktitle = {Proceedings of the Example Conference},
%%   year      = {2024},
%% }
%%
%% @article{jones2023analysis,
%%   author  = {Jones, Carol and Patel, Anish},
%%   title   = {An Analysis of Something},
%%   journal = {Journal of Examples},
%%   volume  = {42},
%%   number  = {3},
%%   pages   = {123--145},
%%   year    = {2023},
%% }
